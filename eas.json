{
  "cli": {
    "version": ">= 5.0.0",
    "appVersionSource": "local"
  },
  "build": {
    "preview": {
      "android": {
        "buildType": "apk",
        "env": {
          "NPM_CONFIG_LEGACY_PEER_DEPS": "true",
          "EAS_BUILD_NO_EXPO_GO_WARNING": "true"
        }
      }
    },
    "production": {
      "android": {
        "buildType": "apk",
        "env": {
          "NPM_CONFIG_LEGACY_PEER_DEPS": "true",
          "EAS_BUILD_NO_EXPO_GO_WARNING": "true"
        }
      }
    }
  }
}
